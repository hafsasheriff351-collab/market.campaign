      <column caption='Profit' datatype='real' name='[Calculation_1132563075391489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue_USD]) - SUM([Cost_USD])' />
      </column>
      <column caption='CTR' datatype='real' default-format='p0.00%' name='[Calculation_1132563076149250]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Clicks]) / SUM([Impressions])' />
      </column>
      <column caption='Roi calc' datatype='real' default-format='p0.00%' name='[Calculation_1132563298705414]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Revenue_USD]) - SUM([Cost_USD])) / SUM([Cost_USD])' />
      </column>
      <column caption='Lead -&gt; conversions' datatype='real' name='[Calculation_1132563325128717]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Conversions]) / SUM([Leads])' />
      </column>
      <column caption='Total Profit' datatype='real' name='[Calculation_1132563402285070]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1132563075391489] = [Revenue_USD] - [Cost_USD]' />
      </column>
